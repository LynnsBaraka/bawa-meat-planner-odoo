<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Plan List View -->
    <record id="view_bawa_plan_list" model="ir.ui.view">
        <field name="name">bawa.plan.list</field>
        <field name="model">bawa.plan</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'committed'" decoration-muted="state == 'cancelled'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="plan_date"/>
                <field name="state" widget="badge" decoration-success="state == 'committed'" decoration-info="state == 'draft'" decoration-muted="state == 'cancelled'" decoration-warning="state == 'in_progress'" decoration-primary="state == 'done'"/>
                <field name="hq_required"/>
                <field name="fq_required"/>
                <field name="recursive_driver_used"/>
                <field name="production_count" string="MOs"/>
                <field name="yield_template_id"/>
            </list>
        </field>
    </record>

    <!-- Plan Form View -->
    <record id="view_bawa_plan_form" model="ir.ui.view">
        <field name="name">bawa.plan.form</field>
        <field name="model">bawa.plan</field>
        <field name="arch" type="xml">
            <form string="Butchery Production Plan">
                <header>
                    <button name="action_commit" string="Commit Plan and Create MOs"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-secondary"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,committed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_productions" type="object"
                                class="oe_stat_button" icon="fa-industry"
                                invisible="production_count == 0">
                            <field name="production_count" widget="statinfo"
                                   string="Manufacturing Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="plan_date"/>
                            <field name="yield_template_id"/>
                            <field name="recursive_driver_used"/>
                        </group>
                        <group>
                            <field name="hq_required"/>
                            <field name="fq_required"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Planning Orders" name="orders">
                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_level"/>
                                    <field name="qty"/>
                                    <field name="due_date"/>
                                    <field name="sale_order_line_id" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Plan Result (JSON)" name="plan_json">
                            <field name="plan_result_json" widget="code" options="{'mode': 'json'}" readonly="1"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Plan History Action -->
    <record id="action_bawa_plan_list" model="ir.actions.act_window">
        <field name="name">Plan History</field>
        <field name="res_model">bawa.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No plans generated yet
            </p>
            <p>
                Use the Planning Engine to generate and save production plans.
                Committed plans create Manufacturing Orders automatically.
            </p>
        </field>
    </record>

    <!-- Planning Engine Client Action -->
    <record id="action_bawa_planning_engine" model="ir.actions.client">
        <field name="name">Planning Engine</field>
        <field name="tag">bawa_planning_engine</field>
    </record>

    <!-- Supply Planner Client Action -->
    <record id="action_bawa_supply_planner" model="ir.actions.client">
        <field name="name">Supply Planner</field>
        <field name="tag">bawa_supply_planner</field>
    </record>

</odoo>
